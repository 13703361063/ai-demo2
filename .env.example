## App
APP_NAME="AI Chat Assistant"

## Tongyi Qwen (DashScope OpenAI-compatible, server-side only)
# Put your real key into `.env` (do NOT commit it)
DASHSCOPE_API_KEY="replace_me"

# OpenAI-compatible base URL
DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# Model name (examples: qwen-turbo, qwen-plus)
DASHSCOPE_MODEL="qwen-plus"

## Safety / limits
MAX_INPUT_CHARS=12000
RATE_LIMIT_PER_IP_PER_MIN=30

## Database (Prisma / PostgreSQL)
# For local development with SQLite:
# DATABASE_URL="file:./dev.db"

# For Vercel Postgres (set these in Vercel Dashboard):
# DATABASE_URL="postgres://default:xxx@xxx.postgres.vercel-storage.com/verceldb?pgbouncer=true&connect_timeout=15"
# DIRECT_DATABASE_URL="postgres://default:xxx@xxx.postgres.vercel-storage.com/verceldb?connect_timeout=15"
DATABASE_URL=""
DIRECT_DATABASE_URL=""

